# Backend provider keys. Use real values only in a local .env or secret manager.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
OPENAI_API_KEY=

# Backend runtime configuration.
NODE_ENV=development
HOST=127.0.0.1
PORT=8787
PUBLIC_API_BASE_URL=http://localhost:8787

# Provider model defaults. Keep configurable for fast swaps.
GEMINI_RESEARCH_MODEL=gemini-3.1-pro-preview
ANTHROPIC_WRITER_MODEL=claude-opus-4-6
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=pcm_24000
OPENAI_IMAGE_MODEL=gpt-image-2

# Guardrails. These are planning defaults and should be enforced server-side.
MAX_STORY_MINUTES=65
MAX_TTS_CHARACTERS=52000
MAX_JOB_COST_USD=12.00
MAX_DAILY_COST_USD=40.00
MAX_RETRY_COST_USD=21.00
MAX_PAID_RETRIES_PER_JOB=1
MAX_PAID_PROVIDER_ATTEMPTS_PER_STAGE=2
PROVIDER_KILL_SWITCH=false

# Owner-only access. Hash local enrollment/device tokens with DEVICE_TOKEN_HMAC_SECRET.
DEVICE_TOKEN_HMAC_SECRET=
OWNER_DEVICE_TOKEN_HASHES=
ENROLLMENT_ADMIN_SECRET=
ENROLLMENT_CODE_TTL_SECONDS=600
ENROLLMENT_STORE_PATH=data/enrollment.json
ENABLE_LOCAL_ENROLLMENT=true
DATA_DIR=data
JOB_STORE_PATH=data/jobs.json
QUEUE_STORE_PATH=data/queue.json
WORKER_POLL_INTERVAL_MS=5000

# Provider enablement flags. Keep false until keys and budget caps are ready.
ENABLE_GEMINI_RESEARCH=false
ENABLE_ANTHROPIC_WRITING=false
ENABLE_ELEVENLABS_TTS=false
ENABLE_OPENAI_IMAGES=false

# Storage placeholders, to be finalized when storage is selected.
STORAGE_PROVIDER=local
STORAGE_BUCKET=
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_SIGNING_SECRET=

# Optional local output directories for provider checks.
REAL_PROVIDER_SMOKE_OUTPUT_DIR=
FULL_LENGTH_ACCEPTANCE_OUTPUT_DIR=
FULL_LENGTH_ACCEPTANCE_BUDGET_CAP_USD=25
FULL_LENGTH_ACCEPTANCE_TARGET_MINUTES=60
